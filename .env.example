# Environment variables for ariqmuldi.com
#
# LOCALHOST ONLY. Copy this file to `.env` for local development:
#
#     cp .env.example .env
#
# PRODUCTION NEEDS NONE OF THESE. The deployed site (Vercel) is a read-only
# showcase: the /content-generation authoring tool refuses to edit in
# production regardless of env, and dev/build/Vercel never call the AI —
# they only read the committed JSON. So leave all of these UNSET in prod.

# --- AI content generation (Google Gemini) ---
# Used only by `npm run generate:content` (and generate:work-experience-content
# / generate:project-content) to draft work/project content locally.
GEMINI_API_KEY=your-gemini-api-key-here
# Default Gemini model; the /content-generation UI can override per generate run.
GEMINI_MODEL=gemini-2.5-flash-lite

# --- /content-generation authoring tool (server-only — never NEXT_PUBLIC_) ---
# Editing only works on localhost; production is always read-only.
# Set the password to a long random passphrase you control:
CONTENT_GENERATION_PASSWORD=change-me-to-a-long-random-passphrase
# Signing secret for the auth cookie; use a long random hex string, e.g.
#     openssl rand -hex 32
CONTENT_GENERATION_SESSION_SECRET=change-me-to-a-random-hex-string
